# Gini Mobile - Environment Configuration Example
# Copy this file to .env and fill in the production/staging values

# API Configuration
API_BASE_URL=https://api.gini-fintech.com/v1
API_TIMEOUT=15000

# CredoLab SDK Configuration
CREDOLAB_SITE_ID=your_site_id_here
CREDOLAB_API_KEY=your_api_key_here

# Payment & Encryption
MERCHANT_QR_SECRET=your_qr_secret_here
STORAGE_ENCRYPTION_KEY=your_storage_key_here
